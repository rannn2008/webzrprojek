{
  "rewrites": [
    {
      "source": "/",
      "destination": "/webzrpromosi/index.html"
    },
    {
      "source": "/admin",
      "destination": "/webzrpromosi/adminpunyazr1.html"
    },
    {
      "source": "/adminpunyazr",
      "destination": "/webzrpromosi/adminpunyazr1.html"
    },
    {
      "source": "/adminpunyazr1",
      "destination": "/webzrpromosi/adminpunyazr1.html"
    },
    {
      "source": "/adminzr",
      "destination": "/webzrpromosi/adminpunyazr1.html"
    },
    {
      "source": "/foto2/:path*",
      "destination": "/webzrpromosi/foto2/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/webzrpromosi/$1"
    }
  ],
  "cleanUrls": true
}
